# 语音识别分析系统 - Crontab 配置示例
# 用于定时清理日志和系统维护

# 每天凌晨2点清理过期日志
0 2 * * * cd /Users/ylm/IdeaProjects/voice-analysis-web && /usr/bin/python3 cleanup_logs.py >> logs/cron.log 2>&1

# 每周日凌晨3点备份数据库
0 3 * * 0 mysqldump -u root -p'your_password' voice_analysis > backups/voice_analysis_$(date +\%Y\%m\%d).sql

# 每小时检查服务状态（可选）
0 * * * * curl -f http://localhost:8501 || echo "Service down at $(date)" | mail -s "Service Alert" admin@example.com
